{
  "name": "react-theming-engine",
  "version": "0.1.1",
  "description": "A 3-layer React theming engine: Brand Palette → Semantic Tokens → CSS Variables",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tailwind": {
      "import": {
        "types": "./dist/tailwind/plugin.d.ts",
        "default": "./dist/tailwind/plugin.js"
      },
      "require": {
        "types": "./dist/tailwind/plugin.d.cts",
        "default": "./dist/tailwind/plugin.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "react",
    "theming",
    "theme-engine",
    "design-tokens",
    "css-variables",
    "dynamic-theming",
    "dark-mode",
    "light-mode",
    "design-system",
    "tailwindcss",
    "tailwind-plugin",
    "multi-theme",
    "color-scheme",
    "theme-provider",
    "custom-properties",
    "react-theming",
    "react-theme",
    "branding",
    "runtime-theming",
    "semantic-tokens",
    "color-palette",
    "theme-switcher",
    "theme-toggle",
    "brand-colors",
    "ui-tokens",
    "react-hooks",
    "useTheme",
    "react18",
    "typescript",
    "zero-runtime",
    "white-label",
    "multi-brand",
    "react-design-system",
    "token-based-design"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abilash-19/react-theming-engine"
  },
  "author": "Abilash",
  "homepage": "https://react-theme-engine.vercel.app",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  }
}